@model CarRentalPlatform.Models.VehicleViewModel

@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="container mt-4">
    <h2 class="mb-4 text-danger">Delete Vehicle</h2>

    <p>Are you sure you want to delete this vehicle?</p>

    <dl class="row">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Vehicle Code</dt>
        <dd class="col-sm-9">@Model.VehicleCode</dd>

        <dt class="col-sm-3">Location ID</dt>
        <dd class="col-sm-9">@Model.LocationId</dd>

        <dt class="col-sm-3">Vehicle Type</dt>
        <dd class="col-sm-9">@Model.VehicleType</dd>

        <dt class="col-sm-3">Vehicle Status</dt>
        <dd class="col-sm-9">@Model.VehicleStatus</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>